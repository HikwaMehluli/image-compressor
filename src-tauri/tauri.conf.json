{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "Image Compressor",
	"version": "2.0.0",
	"identifier": "com.hikwamehluli.imagecompressor",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "image-compressor",
				"width": 900,
				"height": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"android": {
			"minSdkVersion": 28,
			"versionCode": 100
		},
		"macOS": {
			"dmg": {
				"windowSize": {
					"width": 660,
					"height": 400
				}
			}
		}
	},
	"plugins": {
		"dialog": null,
		"fs": null,
		"path": null
	}
}