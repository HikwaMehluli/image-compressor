{
	"name": "image-compressor",
	"version": "1.0.2",
	"description": "Simple Image Compression Tool",
	"author": "thatAfro",
	"main": "main.js",
	"scripts": {
		"start-demo": "electron .",
		"css-prod": "sass --no-source-map --watch scss/_entry.scss:css/app.css --style compressed",
		"css-dev": "sass --no-source-map --watch scss/_entry.scss:css/app.css",
		"windows-app": "electron-packager . image-compressor --overwrite --platform=win32 --arch=x64 --icon=assets/icons/win/icon.ico --out=dist/",
		"macOS-app": "electron-packager . image-compressor --overwrite --platform=darwin --arch=x64 --icon=assets/icons/win/icon.ico --out=dist/",
		"linux-app": "electron-packager . image-compressor --overwrite --platform=linux --arch=x64 --icon=assets/icons/win/icon.ico --out=dist/",

		"Crazy": "electron-packager . image-compressor --overwrite --asar --platform=win32 --arch=ia32 --icon=assets/icons/win/icon.ico --prune=true --out=release-builds --version-string.CompanyName=CE --version-string.FileDescription=CE "
	},
	"devDependencies": {
		"electron": "^14.0.1",
		"electron-packager": "^15.4.0"
	}
}
