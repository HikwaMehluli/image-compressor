{
	"name": "image-compressor",
	"version": "1.0.2",
	"description": "Simple Image Compression Tool",
	"author": "thatAfro",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"css-prod": "sass --no-source-map --watch scss/_entry.scss:css/style.css --style compressed",
		"css-dev": "sass --no-source-map --watch scss/_entry.scss:css/style.css",
		"windows-app": "electron-packager . image-compressor --overwrite --platform=win32 --arch=x64 --icon=assets/icons/win/icon.ico --out=dist/",
		"macOS-app": "electron-packager . image-compressor --overwrite --platform=darwin --arch=x64 --icon=assets/icons/win/icon.ico --out=dist/",
		"linux-app": "electron-packager . image-compressor --overwrite --platform=linux --arch=x64 --icon=assets/icons/win/icon.ico --out=dist/"
	},
	"devDependencies": {}
}
