{
	"name": "image-compressor",
	"version": "1.0.2",
	"description": "Simple Image Compression Tool",
	"author": "thatAfro",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"css-prod": "sass --no-source-map --watch scss/_entry.scss:css/app.css --style compressed",
		"css-dev": "sass --no-source-map --watch scss/_entry.scss:css/app.css",

		"package-mac": "electron-packager . --overwrite --asar=true --platform=darwin --arch=x64 --icon=assets/icons/mac/icon.icns --prune=true --out=release-builds",
		"package-linux": "electron-packager . image-compressor --overwrite --asar=true --platform=linux --arch=x64 --icon=assets/icons/png/512x512.png --prune=true --out=release-builds",
		"package-win": "electron-packager . image-compressor --overwrite --asar=true --platform=win32 --arch=ia32 --icon=assets/icons/win/icon.ico --prune=true --out=release-builds --version-string.CompanyName=CE --version-string.FileDescription=CE --version-string.ProductName=\"Image Compressor\"",

		"create-installer-mac": "electron-installer-dmg ./release-builds/Image\\ Compressor\\ app-darwin-x64/Image\\ Compressor\\ app.app image-compressor --out=release-builds --overwrite --icon=assets/icons/mac/icon.icns",
		"create-installer-win": "node installers/windows/createinstaller.js"
	},
	"devDependencies": {
		"electron": "^14.0.1",
		"electron-packager": "^15.4.0",
		"electron-winstaller": "^5.0.0"
	}
}
